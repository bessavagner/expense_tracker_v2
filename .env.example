# Django Settings
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# --- Core ---
# In production: generate a fresh strong key, e.g.
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- Database (local dev via Docker Compose) ---
POSTGRES_DB=expense_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- AI Assistant ---
LLM_MODEL=openai:gpt-4o-mini
LLM_API_KEY=sk-your-key-here
ASSISTANT_MAX_HISTORY=20

# --- Production server ---
# Cloud Run / containers inject PORT (defaults to 8080 in the Dockerfile).
# PORT=8080

# ============================================================
# Production (Supabase + Cloud Run) — uncomment & fill for prod
# ============================================================
# DEBUG=False
# ALLOWED_HOSTS=expenses.your-domain.com
# CSRF_TRUSTED_ORIGINS=https://expenses.your-domain.com
#
# DATABASE_URL overrides the individual POSTGRES_* vars above.
# App runtime  -> Supabase Transaction Pooler (port 6543), sslmode=require:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
# Migrations   -> Supabase direct/Session connection (port 5432); the transaction
#                 pooler does not support everything migrations need:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
